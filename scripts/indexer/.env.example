# Option B indexer — VPS environment
# Copy to ~/pepeball-game-day/indexer/.env or export before running daemon.

# Paid RPC (required at 10k+)
HELIUS_API_KEY=your_helius_key
# Or full URL:
# RPC_URL=https://devnet.helius-rpc.com/?api-key=...

SOLANA_CLUSTER=devnet

# Local data (participant DB, manifests, gap reports)
INDEXER_DATA_DIR=~/pepeball-game-day/indexer

# Registry mints (comma-separated). Defaults to devnet/trio-mints.json if unset.
# REGISTRY_MINTS=master,pump,trix...

# Static USD per token for eligibility scan (tune before draw)
STATIC_USD_PER_TOKEN=0.0001
TOKEN_DECIMALS=6

# Daemon timing
INDEXER_SYNC_INTERVAL_MS=300000
INDEXER_HOLDER_SCAN_EVERY=12
INDEXER_STALE_MS=900000

# Public JSON for site (default: v2turbo/public/indexer-status-public.json)
# INDEXER_STATUS_PUBLIC_PATH=/var/www/pepeball/indexer-status-public.json
