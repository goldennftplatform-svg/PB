{
  "name": "pepball-bot-scripts",
  "version": "1.0.0",
  "description": "Automated bot scripts for PEPEBALL contract testing",
  "scripts": {
    "index-winners": "node helius-winner-indexer.js",
    "check-participant": "node participant-account-helper.js",
    "tax:status": "node tax-pipeline-status.js",
    "tax:mint": "node create-devnet-taxed-master-mint.js",
    "tax:pool": "node create-devnet-taxed-orca-pool.js",
    "tax:withdraw": "node withdraw-token2022-fees.js",
    "tax:drip": "node harmonized-drip-settlement.js",
    "indexer:sync-round": "node indexer/sync-round-from-ledger.js",
    "indexer:participants": "node indexer/run-index-participants.js",
    "indexer:holders": "node indexer/run-holder-scan.js",
    "indexer:gap": "node indexer/run-registration-gap.js",
    "indexer:manifest": "node indexer/publish-manifest.js",
    "indexer:daemon": "node indexer/run-daemon.js",
    "indexer:export": "node -e \"require('./lib/indexer-public-export').exportPublicStatus()\""
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@orca-so/common-sdk": "^0.7.1",
    "@orca-so/whirlpools": "^8.0.1",
    "@orca-so/whirlpools-sdk": "^0.21.0",
    "@solana/kit": "^7.0.0",
    "@solana/spl-token": "^0.3.0",
    "@solana/web3.js": "^1.87.0",
    "decimal.js": "^10.6.0"
  }
}
