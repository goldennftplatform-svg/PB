# ─── Production switch (set when you mint the real game token + new jackpot wallet) ───
# Leave unset to use proof token and current default wallet.
# VITE_PEPEBALL_MINT=YourProductionTokenMintAddressHere
# VITE_TAX_RECIPIENT=YourNewJackpotTaxWalletAddress

# ─── Optional (only if your token / config differs) ───
# VITE_TOKEN_DECIMALS=6
# VITE_MIN_HOLDING_TOKENS=1000000
# VITE_TOKEN_TAX_BPS=250

# ─── Chain / API (Vercel or local override) ───
# VITE_CHAIN=solana_mainnet
# VITE_ENV=PREVIEW
# VITE_PRIVY_APP_ID=your-privy-app-id
