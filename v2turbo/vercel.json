{
  "framework": null,
  "buildCommand": "bun run vercel-build",
  "outputDirectory": "dist",
  "installCommand": "bun install --frozen-lockfile",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate, max-age=0" }
      ]
    }
  ]
}
