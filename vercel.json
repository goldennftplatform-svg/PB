{
  "framework": null,
  "buildCommand": "cd v2turbo && bun run vercel-build-vite",
  "outputDirectory": "v2turbo/dist",
  "installCommand": "cd v2turbo && bun install",
  "bunVersion": "1.x",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate, max-age=0" }
      ]
    }
  ]
}
